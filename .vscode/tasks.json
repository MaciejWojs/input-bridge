{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cleanup",
            "type": "shell",
            "detail": "Removes build artifacts and prebuilds. Also removes the packed tarball if it exists.",
            "linux": {
                "command": "rm -rf build dist prebuilds maciejwojs-input-bridge-*.tgz playground/input_bridge_addon.node",
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-NoProfile",
                    "-Command",
                    "Remove-Item -Recurse -Force build,dist,prebuilds,playground/input_bridge_addon.node,maciejwojs-input-bridge-*.tgz -ErrorAction SilentlyContinue"
                ]
            },
            "presentation": {
                "reveal": "silent",
                "clear": true,
                "close": true
            },
            "group": "build",
            "icon": {
                "id": "trashcan",
                "color": "terminal.ansiRed"
            }
        },
        {
            "label": "build",
            "detail": "Compiles TypeScript types. Does not build the native addon.",
            "type": "shell",
            "command": "bun run build",
            "problemMatcher": [
                "$tsc"
            ],
            "group": "build",
            "icon": {
                "id": "gear"
            },
            "presentation": {
                "reveal": "silent",
                "focus": false,
                "panel": "dedicated",
                "clear": false,
                "close": true
            }
        },
        {
            "label": "rebuild",
            "detail": "Rebuilds the native addon.",
            "type": "shell",
            "command": "bun rebuild",
            "group": "build",
            "icon": {
                "id": "refresh"
            }
        },
        {
            "label": "prebuild",
            "detail": "Creates prebuilt binaries for the native addon.",
            "type": "shell",
            "command": "bun prebuildify",
            "group": "build",
            "icon": {
                "id": "cloud-upload"
            }
        },
        {
            "label": "prepare",
            "detail": "Prepares the environment for building. (cleanup+build+rebuild)",
            "dependsOn": [
                "cleanup",
                "make addon and compile types"
            ],
            "dependsOrder": "sequence",
            "hide": true,
            "group": "build"
        },
        {
            "label": "make addon and compile types",
            "detail": "Builds the native addon and compiles TypeScript types.",
            "dependsOn": [
                "build",
                "rebuild"
            ],
            "dependsOrder": "parallel",
            "hide": true,
            "group": "build"
        },
        {
            "label": "pack",
            "detail": "Packs the module into a tarball using bun. Depends on prepare and prebuild to ensure everything is up to date.",
            "type": "shell",
            "command": "bun pm pack",
            "dependsOn": [
                "prepare",
                "prebuild"
            ],
            "dependsOrder": "sequence",
            "presentation": {
                "reveal": "always",
                "clear": true
            },
            "icon": {
                "id": "package"
            },
            "group": "build"
        },
        {
            "label": "playground",
            "detail": "Runs the playground script. Depends on prepare to ensure the addon is built and ready.",
            "type": "shell",
            "command": "cp ${workspaceFolder}/build/Release/input_bridge_addon.node ${workspaceFolder}/playground && bun run playground",
            "dependsOn": [
                "prepare"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "clear": true,
                "focus": true,
            },
            "icon": {
                "id": "play"
            },
            "group": "build"
        },
        {
            "label": "playground (X11)",
            "detail": "Rebuilds the addon with X11 backend and runs the playground script.",
            "type": "shell",
            "command": "use_x11_backend=1 bun rebuild && cp ${workspaceFolder}/build/Release/input_bridge_addon.node ${workspaceFolder}/playground && bun run playground",
            "dependsOn": [
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "clear": true,
                "focus": true
            },
            "icon": {
                "id": "play",
                "color": "terminal.ansiBlue"
            },
            "group": "build"
        }
    ]
}